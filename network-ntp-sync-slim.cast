[641.929771, "o", "\u001b]10;?\u0007\u001b]11;?\u0007"]
[641.930725, "o", "\u001b[1;1H\u001b[34m# Use public servers from the pool.ntp.org project.\r\n# Please consider joining the pool (https://www.pool.ntp.org/join.html).\u001b[m\u001b[2;73H\u001b[K\u001b[3;1Hpool 2.rocky.pool.ntp.org iburst\u001b[3;33H\u001b[K\u001b[5;1H\u001b[34m# Use NTP servers from DHCP.\u001b[m\r\nsourcedir /run/chrony-dhcp\r\n\r\n\u001b[34m# Record the rate at which the system clock gains/losses time.\u001b[m\r\ndriftfile /var/lib/chrony/drift\r\n\r\n\u001b[34m# Allow the system clock to be stepped in the first three updates\r\n# if its offset is larger than 1 second.\u001b[m\r\nmakestep 1.0 3\r\n\r\n\u001b[34m# Enable kernel synchronization of the real-time clock (RTC).\u001b[m\r\nrtcsync\r\n\r\n\u001b[34m# Enable hardware timestamping on all interfaces that support it.\r\n#hwtimestamp *\r\n\r\n# Increase the minimum number of selectable sources required to adjust\r\n# the system clock.\r\n#minsources 2\r\n\r\n# Allow NTP client access from local network.\r\n#allow 192.168.0.0/16\r\n\r\n# Serve time even if not synchronized to a time source.\u001b[m\u001b[29;81H1,1\u001b[11CTop\u001b[1;1H\u001b[?25h"]
[641.949171, "o", "\u001bP+q436f\u001b\\\u001bP+q6b75\u001b\\\u001bP+q6b64\u001b\\\u001bP+q6b72\u001b\\\u001bP+q6b6c\u001b\\\u001bP+q2332\u001b\\\u001bP+q2334\u001b\\\u001bP+q2569\u001b\\\u001bP+q2a37\u001b\\\u001bP+q6b31\u001b\\"]
[641.949866, "o", "\u001bP$q q\u001b\\\u001b[?12$p"]
[641.950357, "o", "\u001b[?25l\u001b[29;71H:\u001b[1;1H\u001b[29;72H1\u001b[1;1H\u001b[29;73He\u001b[1;1H\u001b[29;74H1\u001b[1;1H\u001b[29;75He\u001b[1;1H\u001b[29;76H/\u001b[1;1H\u001b[29;77H1\u001b[1;1H\u001b[29;78He\u001b[1;1H\u001b[29;79H1\u001b[1;1H\u001b[29;80He\u001b[1;1H"]
[641.952317, "o", "\u001b[29;71H          \u001b[1;1H\u001b[27m\u001b[23m\u001b[29m\u001b[m\u001b[H\u001b[2J\u001b[1;1H\u001b[96m# Use public servers from the pool.ntp.org project.\r\n# Please consider joining the pool (https://www.pool.ntp.org/join.html).\u001b[m\r\npool 2.rocky.pool.ntp.org iburst\r\n\r\n\u001b[96m# Use NTP servers from DHCP.\u001b[m\r\nsourcedir /run/chrony-dhcp\r\n\r\n\u001b[96m# Record the rate at which the system clock gains/losses time.\u001b[m\r\ndriftfile /var/lib/chrony/drift\r\n\r\n\u001b[96m# Allow the system clock to be stepped in the first three updates\r\n# if its offset is larger than 1 second.\u001b[m\r\nmakestep 1.0 3\r\n\r\n\u001b[96m# Enable kernel synchronization of the real-time clock (RTC).\u001b[m\r\nrtcsync\r\n\r\n\u001b[96m# Enable hardware timestamping on all interfaces that support it.\r\n#hwtimestamp *\r\n\r\n# Increase the minimum number of selectable sources required to adjust\r\n# the system clock.\r\n#minsources 2\r\n\r\n# Allow NTP client access from local network.\r\n#allow 192.168.0.0/16\r\n\r\n# Serve time even if not synchronized to a time source.\u001b[m\u001b[29;81H1,1\u001b[11CTop\r\"/etc/chrony.conf\" 50L, 1370B\u001b[1;1H\u001b[?25h"]
