[279.147175, "o", "\u001b[?1049h\u001b[22;0;0t\u001b[>4;2m\u001b[?1h\u001b=\u001b[?2004h\u001b[?1004h\u001b[1;29r\u001b[?12h\u001b[?12l\u001b[22;2t\u001b[22;1t"]
[279.150275, "o", "\u001b[27m\u001b[23m\u001b[29m\u001b[m\u001b[H\u001b[2J\u001b[?25l\u001b[29;1H\"/etc/chrony.conf\""]
[279.1511, "o", " 50L, 1389B"]
[279.15586, "o", "\u001b[2;1H▽\u001b[6n\u001b[2;1H  \u001b[3;1H\u001bPzz\u001b\\\u001b[0%m\u001b[6n\u001b[3;1H           \u001b[1;1H"]
[279.156205, "o", "\u001b[>c\u001b]10;?\u0007\u001b]11;?\u0007"]
[279.157768, "o", "\u001b[1;1H\u001b[34m# Use NTP servers from DHCP.\u001b[m\r\nsourcedir /run/chrony-dhcp\u001b[2;27H\u001b[K\u001b[3;1H\u001b[K\u001b[4;1H\u001b[34m# Record the rate at which the system clock gains/losses time.\u001b[m\r\ndriftfile /var/lib/chrony/drift\r\n\r\n\u001b[34m# Allow the system clock to be stepped in the first three updates\r\n# if its offset is larger than 1 second.\u001b[m\r\nmakestep 1.0 3\r\n\r\n\u001b[34m# Enable kernel synchronization of the real-time clock (RTC).\u001b[m\r\nrtcsync\r\n\r\n\u001b[34m# Enable hardware timestamping on all interfaces that support it.\r\n#hwtimestamp *\r\n\r\n# Increase the minimum number of selectable sources required to adjust\r\n# the system clock.\r\n#minsources 2\r\n\r\n# Allow NTP client access from local network.\r\n#allow 192.168.0.0/16\u001b[m\r\nallow 172.16.1.0/24\r\n\u001b[34m# Serve time even if not synchronized to a time source.\r\n#local stratum 10\r\n\r\n# Require authentication (nts or key option) for all NTP sources.\r\n#authselectmode require\u001b[m\u001b[29;88H27,19\u001b[9C18%\u001b[23;19H\u001b[?25h"]
[279.196069, "o", "\u001bP+q436f\u001b\\\u001bP+q6b75\u001b\\\u001bP+q6b64\u001b\\\u001bP+q6b72\u001b\\\u001bP+q6b6c\u001b\\\u001bP+q2332\u001b\\\u001bP+q2334\u001b\\\u001bP+q2569\u001b\\\u001bP+q2a37\u001b\\\u001bP+q6b31\u001b\\\u001bP$q q\u001b\\\u001b[?12$p"]
[279.196761, "o", "\u001b[?25l\u001b[29;78He\u001b[23;19H\u001b[29;79H1\u001b[23;19H\u001b[29;80He\u001b[23;19H\u001b[29;81H/\u001b[23;19H\u001b[29;82H1\u001b[23;19H\u001b[29;83He\u001b[23;19H\u001b[29;84H1\u001b[23;19H\u001b[29;85He\u001b[23;19H\u001b[29;86H/\u001b[23;19H\u001b[29;87H1\u001b[23;19H"]
[279.200155, "o", "\u001b[29;78H          \u001b[23;19H\u001b[27m\u001b[23m\u001b[29m\u001b[m\u001b[H\u001b[2J\u001b[1;1H\u001b[96m# Use NTP servers from DHCP.\u001b[m\r\nsourcedir /run/chrony-dhcp\r\n\r\n\u001b[96m# Record the rate at which the system clock gains/losses time.\u001b[m\r\ndriftfile /var/lib/chrony/drift\r\n\r\n\u001b[96m# Allow the system clock to be stepped in the first three updates\r\n# if its offset is larger than 1 second.\u001b[m\r\nmakestep 1.0 3\r\n\r\n\u001b[96m# Enable kernel synchronization of the real-time clock (RTC).\u001b[m\r\nrtcsync\r\n\r\n\u001b[96m# Enable hardware timestamping on all interfaces that support it.\r\n#hwtimestamp *\r\n\r\n# Increase the minimum number of selectable sources required to adjust\r\n# the system clock.\r\n#minsources 2\r\n\r\n# Allow NTP client access from local network.\r\n#allow 192.168.0.0/16\u001b[m\r\nallow 172.16.1.0/24\r\n\u001b[96m# Serve time even if not synchronized to a time source.\r\n#local stratum 10\r\n\r\n# Require authentication (nts or key option) for all NTP sources.\r\n#authselectmode require\u001b[m\u001b[29;88H27,19\u001b[9C18%\r\"/etc/chrony.conf\" 50L, 1389B\u001b[23;19H\u001b[?25h"]
